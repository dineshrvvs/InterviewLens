{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/preload/overlay.d.ts",
    "src/preload/audio.d.ts",
    "src/preload/stt.d.ts",
    "src/preload/shot.d.ts",
    "src/preload/llm.d.ts",
    "src/preload/settings.d.ts"
  ]
}
